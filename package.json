{
  "name": "sauryctf",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n BE,FE -c blue,green \"pnpm dev:backend\" \"pnpm dev:frontend\"",
    "dev:backend": "go run ./cmd/server",
    "dev:frontend": "pnpm --filter sauryctf-frontend dev:local",
    "check:auth-redirects": "powershell -ExecutionPolicy Bypass -File ./scripts/check-auth-redirects.ps1",
    "smoke:local": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-local.ps1 -StartBackend",
    "smoke:local:docker": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-local.ps1 -DynamicMode docker -StartBackend",
    "test": "pnpm test:backend && pnpm test:frontend",
    "test:backend": "go test ./...",
    "test:frontend": "pnpm --filter sauryctf-frontend typecheck",
    "generate:api:backend": "go run github.com/oapi-codegen/oapi-codegen/v2/cmd/oapi-codegen@v2.7.0 --config api/oapi-codegen.yaml api/openapi.yaml",
    "generate:api:frontend": "openapi-typescript api/openapi.yaml -o frontend/app/types/api.d.ts",
    "generate:api": "pnpm generate:api:backend && pnpm generate:api:frontend",
    "generate": "pnpm generate:api && pnpm --filter sauryctf-frontend generate",
    "typecheck": "pnpm --filter sauryctf-frontend typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "openapi-typescript": "^6.7.6"
  }
}
