# SauryCTF Configuration
# HOST: default 0.0.0.0 (all interfaces). Set to 127.0.0.1 to avoid Windows firewall prompts.
HOST=127.0.0.1
PORT=8080
# DATABASE_URL: if empty, uses local SQLite (sauryctf.db). Set to PostgreSQL URL for production.
# DATABASE_URL=postgresql://user:pass@localhost:5432/sauryctf
JWT_SECRET=dev-secret-change-in-production
INSTANCE_LEASE_DURATION_MINUTES=30
INSTANCE_EXTENSION_DURATION_MINUTES=30
INSTANCE_RENEWAL_WINDOW_MINUTES=10
INSTANCE_TEAM_ACTIVE_LIMIT=3
